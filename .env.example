# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# OpenAI API Key
OPENAI_API_KEY=your-openai-api-key

# OpenAI Model (default: gpt-4o for best available; change to desired model)
OPENAI_MODEL=gpt-4o

# Base URL for serving HTML reports (e.g., https://yourdomain.com)
REPORT_BASE_URL=http://localhost:8080

# Server port for serving HTML reports
REPORT_SERVER_PORT=8080

# Database path
DATABASE_PATH=data/jobs.db

# Static files directory
STATIC_DIR=static
